# PHS API Environment Configuration
# Deploy to /etc/default/phs-api on the server
# Then update phs-api.service to use: EnvironmentFile=/etc/default/phs-api

# PostgreSQL Connection
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Authentication Secret (change this to a strong, random value!)
AUTH_SECRET=phs-super-secret-2026

# API Configuration
API_PORT=3210
NODE_ENV=production

# Database Configuration
USE_POSTGRES_READ=true
USE_POSTGRES_WRITE=true
ENABLE_DUAL_WRITE=true

# Logging
LOG_DIR=/var/log/phs-api
